# MongoDB Atlas connection string (db: bytebulletin)
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/bytebulletin

# Groq API key (console.groq.com) — pipeline-worker only
GROQ_API_KEY=gsk_...

# Owner password hash (scrypt) — web-client only.
# Generate with: pnpm auth:hash  (prompts for a password, writes this var)
OWNER_PASSWORD_HASH=scrypt:...

# Similarity keep-threshold for the pipeline (optional, default 0.35)
MIN_SCORE=0.35
